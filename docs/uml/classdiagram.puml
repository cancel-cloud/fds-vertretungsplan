@startuml
skinparam classAttributeIconSize 0

class HomePage <<page>> {
  +redirectByUserState()
}

class DashboardClient <<client>> {
  +renderDashboard()
}

class RegisterPage <<page>> {
  +submitRegistration()
}

class AdminPanel <<client>> {
  +manageTeachers()
  +manageUsers()
  +sendPushTest()
}

class useSubstitutions <<hook>> {
  +substitutions
  +isLoading
  +error
  +refetch()
}

class SubstitutionRoute <<api>> {
  +GET(req)
}

class PushDispatchRoute <<api>> {
  +POST(req)
}

class DataProcessing <<service>> {
  +processApiResponse(rows)
  +filterSubstitutions(items, filter)
}

class Prisma <<infrastructure>>
class QStashSchedule <<infrastructure>>
class WebUntis <<external>>

HomePage --> DashboardClient : leitet weiter / startet UI
RegisterPage --> HomePage : fuehrt nach Login in Nutzerfluss
DashboardClient --> useSubstitutions : fordert Vertretungsdaten an
DashboardClient --> AdminPanel : trennt Admin-Funktionen
useSubstitutions --> SubstitutionRoute : ruft /api/substitutions auf
SubstitutionRoute --> DataProcessing : normalisiert Rohdaten
SubstitutionRoute --> WebUntis : laedt Vertretungsdaten
AdminPanel --> Prisma : verwaltet Lehrer und Nutzer
QStashSchedule --> PushDispatchRoute : triggert geplanten Dispatch
PushDispatchRoute --> Prisma : laedt Nutzer, Stundenplaene, Subscriptions
PushDispatchRoute --> WebUntis : vergleicht relevante Vertretungen

@enduml
